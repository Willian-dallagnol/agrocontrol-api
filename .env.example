# ─────────────────────────────────────────────────────────────────
#  AgroControl API — variáveis de ambiente
#  Copie para .env e ajuste antes de rodar a aplicação
#  NUNCA commit o .env com valores reais no Git
# ─────────────────────────────────────────────────────────────────

# Servidor
APP_PORT=8080
APP_ENV=development    # development | production

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=troque_para_uma_senha_forte_aqui
DB_NAME=agro_control

# JWT — mín. 32 caracteres, gerado aleatoriamente
# Gere com: openssl rand -hex 32
JWT_SECRET=troque_por_um_segredo_de_pelo_menos_32_caracteres
JWT_EXP_HOURS=24       # validade do token em horas
